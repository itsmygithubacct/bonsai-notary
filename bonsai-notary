#!/usr/bin/env bash
# bonsai-notary — the composed deterministic-inference + on-chain-notary launcher.
#
# Wires four pieces together at run time:
#   * inference engine : ./engine          (trinote under bonsai/src)
#   * on-chain software: ./chain_c         (bonsai_third_entry / agentd CLIs)
#   * on-chain orch.   : ./bsv_third_entry (ChainC backend + agent driver)
#   * notary glue      : this dir          (wallet, launchers, docs, identity)
#
# It runs the engine's run_bonsai_cli through bsv_third_entry.engine_run, which rebinds the
# --onchain Third Entry backend to chain_c. Generated state + secrets live OUTSIDE the repo under
# $BONSAI_NOTARY_HOME (default ~/.local/trinote) — the SAME home the engine and chain_c both use.
#
# Usage:
#   bonsai-notary [MODE] PROMPT [--model 8b|27b] [--receipts] [--cpu-threads N] [--onchain] [--verbose] [extra run_bonsai_cli flags...]
#   bonsai-notary [MODE] [options...] --prompt PROMPT   # explicit prompt when options come first
#
# MODE (default: one-shot):
#   repl            interactive REPL              — omit PROMPT
#   json   PROMPT   structured JSON output
#   (none) PROMPT   one-shot completion
#
# Flags:
#   --model MODEL   notarized model profile: 8b (default) or 27b
#   --receipts      emit a notarized, byte-exact, third-party-verifiable receipt (OFF by default)
#   --cpu-threads N cap OpenMP and supported BLAS runtimes to the actual CPU entitlement
#   --onchain       anchor the receipt's Third Entry via chain_c (DRY-RUN unless --chain-confirm)
#   --verbose       show engine/timing/receipt diagnostics (json/one-shot are output-only by default)
#
# Env:
#   BONSAI_NOTARY_HOME   shared state/secrets home (default ~/.local/trinote)
#   BONSAI_ENGINE_DIR    inference-engine checkout (default ./engine)
#   BONSAI_CHAIN_C_DIR   chain_c checkout         (default ./chain_c)
#   BONSAI_WEIGHTS_REPO  optional local source checkout for 8B weights (default: unset/download)
#   BONSAI_MODEL         default model profile: 8b or 27b (default: 8b)
#   BONSAI_CONTEXT_SIZE  context tokens for either model/backend (default: model/artifact-aware auto)
#   BONSAI_CPU_THREADS   cap OpenMP/BLAS worker threads (default: preserve runtime defaults)
#   BONSAI_GPU=0         force CPU (default uses the GPU producer, auto-falls back to CPU)
#   BONSAI_DRYRUN=1      print the resolved command instead of running it
set -euo pipefail

usage() { awk 'NR==1{next} /^#/{sub(/^# ?/,"");print;next} {exit}' "${BASH_SOURCE[0]}"; exit "${1:-0}"; }

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# --- the pieces (env-overridable; symlinks today, GitHub checkouts later) ---
ENGINE_DIR="${BONSAI_ENGINE_DIR:-$ROOT/engine}"
CHAIN_C_DIR="${BONSAI_CHAIN_C_DIR:-$ROOT/chain_c}"
BSV_TE_DIR="${BONSAI_BSV_TE_DIR:-$ROOT/bsv_third_entry}"
ENGINE_SRC="$ENGINE_DIR/bonsai/src"
export BONSAI_ENGINE_DIR="$ENGINE_DIR" BONSAI_CHAIN_C_DIR="$CHAIN_C_DIR"

# --- unified state/secrets home (engine receipts/keys AND chain_c key files) ---
export BONSAI_NOTARY_HOME="${BONSAI_NOTARY_HOME:-$HOME/.local/trinote}"

# A setup-created AgentTea identity uses stable role key paths under the private state home. Export
# them only when the caller did not choose explicit paths. The same Agent/Counterparty WIF files are
# also passed to the receipt engine below, binding the first two receipt signatures to the public
# keys committed by the on-chain identity instead of silently creating unrelated receipt signers.
ROLE_KEYS_DIR="$BONSAI_NOTARY_HOME/agent/keys"
if [ -z "${ELDER_KEY_FILE:-}" ] && [ -f "$ROLE_KEYS_DIR/elder.key.json" ]; then
    export ELDER_KEY_FILE="$ROLE_KEYS_DIR/elder.key.json"
fi
if [ -z "${AGENT_KEY_FILE:-}" ] && [ -f "$ROLE_KEYS_DIR/agent.key.json" ]; then
    export AGENT_KEY_FILE="$ROLE_KEYS_DIR/agent.key.json"
fi
if [ -z "${COUNTERPARTY_KEY_FILE:-}" ] && [ -f "$ROLE_KEYS_DIR/counterparty.key.json" ]; then
    export COUNTERPARTY_KEY_FILE="$ROLE_KEYS_DIR/counterparty.key.json"
fi

[ -d "$ENGINE_SRC" ] || { echo "bonsai-notary: engine not found at $ENGINE_SRC (check the 'engine' symlink)" >&2; exit 4; }

PY="$ENGINE_DIR/bonsai/.venv/bin/python"; [ -x "$PY" ] || PY="python3"
GPU="${BONSAI_GPU:-1}"

[ $# -ge 1 ] || usage 1
case "$1" in -h|--help|help) usage 0 ;; esac

# Mode: repl | json | (default) one-shot.
mode="oneshot"
case "$1" in repl|json) mode="$1"; shift ;; esac

# A bare prompt is accepted only in the documented, unambiguous position:
# immediately after MODE. If engine options need to come first, --prompt/-p is
# explicit. Never guess among pass-through option values (e.g. `-n 1 prompt`).
prompt_args=()
if [ "$mode" != "repl" ] && [ $# -gt 0 ] && [ "${1:0:1}" != "-" ]; then
    [ -n "$1" ] || { echo "bonsai-notary: one-shot needs a non-empty PROMPT" >&2; exit 2; }
    prompt_args=(-p "$1")
    shift
fi

# --model / --receipts / --verbose / --prompt / --cpu-threads are notary-level switches;
# everything else passes through to run_bonsai_cli.
model="${BONSAI_MODEL:-8b}"; receipt="--no-receipt"; verbose=0
cpu_threads="${BONSAI_CPU_THREADS:-}"; cpu_threads_requested=0; pre=()
[ -z "${BONSAI_CPU_THREADS+x}" ] || cpu_threads_requested=1
while [ $# -gt 0 ]; do
    case "$1" in
        --model)
            [ $# -ge 2 ] || { echo "bonsai-notary: --model needs 8b or 27b" >&2; exit 2; }
            model="$2"; shift 2 ;;
        --model=*)            model="${1#--model=}"; shift ;;
        --receipts|--receipt) receipt="--receipt"; shift ;;
        --no-receipt)         receipt="--no-receipt"; shift ;;
        --verbose|-v)         verbose=1; shift ;;
        --cpu-threads)
            [ $# -ge 2 ] || { echo "bonsai-notary: --cpu-threads needs a positive integer" >&2; exit 2; }
            cpu_threads="$2"; cpu_threads_requested=1; shift 2 ;;
        --cpu-threads=*)      cpu_threads="${1#--cpu-threads=}"; cpu_threads_requested=1; shift ;;
        --prompt|-p)
            [ "$mode" != "repl" ] || { echo "bonsai-notary: repl does not take a prompt" >&2; exit 2; }
            if [ $# -lt 2 ] || [ -z "$2" ]; then
                echo "bonsai-notary: $1 needs a non-empty PROMPT" >&2
                exit 2
            fi
            [ ${#prompt_args[@]} -eq 0 ] || { echo "bonsai-notary: PROMPT supplied more than once" >&2; exit 2; }
            prompt_args=(-p "$2"); shift 2 ;;
        --prompt=*)
            [ "$mode" != "repl" ] || { echo "bonsai-notary: repl does not take a prompt" >&2; exit 2; }
            [ ${#prompt_args[@]} -eq 0 ] || { echo "bonsai-notary: PROMPT supplied more than once" >&2; exit 2; }
            [ -n "${1#--prompt=}" ] || { echo "bonsai-notary: --prompt needs a non-empty PROMPT" >&2; exit 2; }
            prompt_args=(-p "${1#--prompt=}"); shift ;;
        *)                    pre+=("$1"); shift ;;
    esac
done
if [ "$cpu_threads_requested" = 1 ]; then
    [[ "$cpu_threads" =~ ^[1-9][0-9]*$ ]] || {
        echo "bonsai-notary: --cpu-threads/BONSAI_CPU_THREADS must be a positive integer" >&2
        exit 2
    }
    export BONSAI_CPU_THREADS="$cpu_threads"
    # NumPy wheels and the native oracle can resolve to different BLAS runtimes
    # across hosts. Cap every supported runtime to the same provider entitlement.
    export OMP_NUM_THREADS="$cpu_threads"
    export OPENBLAS_NUM_THREADS="$cpu_threads"
    export MKL_NUM_THREADS="$cpu_threads"
    export BLIS_NUM_THREADS="$cpu_threads"
    export VECLIB_MAXIMUM_THREADS="$cpu_threads"
    export NUMEXPR_NUM_THREADS="$cpu_threads"
    export TRINOTE_ORACLE_Q1_THREADS="$cpu_threads"
    export OMP_DYNAMIC=FALSE
    export OMP_WAIT_POLICY="${OMP_WAIT_POLICY:-PASSIVE}"
fi
case "$model" in
    8b|bonsai8|bonsai-8b)     model="8b" ;;
    27b|bonsai27|bonsai-27b)  model="27b" ;;
    *) echo "bonsai-notary: unknown model '$model' (expected 8b or 27b)" >&2; exit 2 ;;
esac
set -- "${pre[@]+"${pre[@]}"}"

if [ "$mode" != "repl" ]; then
    [ ${#prompt_args[@]} -gt 0 ] || {
        echo "bonsai-notary: '$mode' needs a PROMPT immediately after MODE, or explicit --prompt PROMPT when options come first" >&2
        exit 2
    }
fi

# --- resolve model weights from the state home (populated by scripts/fetch_weights.sh) ---
MODELS_DIR="${BONSAI_MODELS_DIR:-$BONSAI_NOTARY_HOME/models}"
model_args=()
case "$model" in
    8b)
        GGUF="$MODELS_DIR/Bonsai-8B-Q1_0.gguf"
        ARTIFACT="$MODELS_DIR/atlas-notarized-bonsai-8b.safetensors"
        IDENTITY="$ROOT/artifacts/atlas-notarized-bonsai-8b.identity.json"
        ;;
    27b)
        GGUF="$MODELS_DIR/Bonsai-27B-Q1_0.gguf"
        ARTIFACT="$MODELS_DIR/Bonsai-27B-Q1_0-int-qwen35.safetensors"
        IDENTITY="$ENGINE_DIR/bonsai/artifacts/atlas-notarized-bonsai-27b.identity.json"
        # Seeded integer top-p is deterministic because its full sampler state
        # is receipt-committed. Keep EOS unpenalized and arrest exact loops with
        # the n-gram guard. Explicit caller flags are appended later and win.
        model_args=(--chat --sampler bonsai27-rec --rep-penalty 1.0 --no-repeat-ngram 4 --max-new 1024)
        if [ "$receipt" = "--receipt" ]; then
            # A 27B receipt must be checked by a separately loaded canonical
            # CPU oracle. Never let an optimized producer verify itself.
            model_args+=(--fast-required --verify-mode fresh-oracle)
        fi
        ;;
esac

if [ ! -e "$GGUF" ] && [ ! -e "$ARTIFACT" ]; then
    if [ "$model" = "27b" ]; then
        echo "bonsai-notary: no 27B weights in $MODELS_DIR — run the engine's Bonsai-27B install/fetch scripts" >&2
    else
        echo "bonsai-notary: no weights in $MODELS_DIR — run: ./scripts/fetch_weights.sh" >&2
        echo "  (set HF_REPO for a real download, or BONSAI_WEIGHTS_REPO to reuse a local checkout)" >&2
    fi
fi

weight_args=()
[ -e "$GGUF" ]     && weight_args+=(--gguf "$GGUF")
[ -e "$ARTIFACT" ] && weight_args+=(--artifact "$ARTIFACT")
[ -e "$IDENTITY" ] && weight_args+=(--identity "$IDENTITY")

gpu_args=(); [ "$GPU" = "1" ] && gpu_args=(--gpu)
signing_args=()
[ -n "${AGENT_KEY_FILE:-}" ] && signing_args+=(--model-key "$AGENT_KEY_FILE")
[ -n "${COUNTERPARTY_KEY_FILE:-}" ] && signing_args+=(--counterparty-key "$COUNTERPARTY_KEY_FILE")

case "$mode" in
    repl)    base=(--repl --chat --fast "${gpu_args[@]+"${gpu_args[@]}"}" "$receipt") ;;
    json)    base=(--json --fast "${gpu_args[@]+"${gpu_args[@]}"}" "$receipt") ;;
    oneshot) base=(--fast "${gpu_args[@]+"${gpu_args[@]}"}" "$receipt") ;;
esac

cmd=("$PY" -m bsv_third_entry.engine_run "${base[@]}" "${weight_args[@]+"${weight_args[@]}"}"
     "${model_args[@]+"${model_args[@]}"}" "${signing_args[@]+"${signing_args[@]}"}"
     "${prompt_args[@]+"${prompt_args[@]}"}" "$@")

# json / one-shot emit only model output unless --verbose; diagnostics go to stderr.
quiet_stderr=0
[ "$mode" != "repl" ] && [ "$verbose" = "0" ] && quiet_stderr=1

export PYTHONPATH="$ENGINE_SRC:$BSV_TE_DIR${PYTHONPATH:+:$PYTHONPATH}"

if [ "${BONSAI_DRYRUN:-0}" = "1" ]; then
    note=""; [ "$quiet_stderr" = "1" ] && note=" 2>/dev/null"
    printf '[bonsai-notary] would run (cwd=%s):' "$ROOT"
    dry_env=(BONSAI_NOTARY_HOME="$BONSAI_NOTARY_HOME" PYTHONPATH="$PYTHONPATH")
    if [ "$cpu_threads_requested" = 1 ]; then
        dry_env+=(BONSAI_CPU_THREADS="$cpu_threads" OMP_NUM_THREADS="$cpu_threads"
                 OPENBLAS_NUM_THREADS="$cpu_threads" MKL_NUM_THREADS="$cpu_threads"
                 BLIS_NUM_THREADS="$cpu_threads" VECLIB_MAXIMUM_THREADS="$cpu_threads"
                 NUMEXPR_NUM_THREADS="$cpu_threads" TRINOTE_ORACLE_Q1_THREADS="$cpu_threads"
                 OMP_DYNAMIC=FALSE
                 OMP_WAIT_POLICY="$OMP_WAIT_POLICY")
    fi
    printf ' %q' "${dry_env[@]}" "${cmd[@]}"; printf '%s\n' "$note"
    exit 0
fi

# When actually broadcasting the Third Entry (--chain-confirm), make the wallet self-sufficient:
#   * funding   — draw the action fee from the wallet's OWN derived UTXOs (no hand-picked FUND_* keyfile)
#   * change    — route change to a FRESH derived address (m/44'/236'/0'/1/i) instead of reusing the Elder
# Both re-derivable from the mnemonic; a caller-set FUND_ACTION_KEY_FILE / CHANGE_ADDRESS always wins.
if [[ " $* " == *" --chain-confirm "* ]]; then
    WPY="$ROOT/.venv/bin/python"; [ -x "$WPY" ] || WPY="$PY"; NW="$ROOT/wallet/notary_wallet.py"
    if [ -f "$NW" ] && [ -z "${FUND_ACTION_KEY_FILE:-}" ]; then
        _fk="$("$WPY" "$NW" fund-key --need 12000 --allow-unconfirmed 2>/dev/null || true)"
        if [ -n "$_fk" ]; then export FUND_ACTION_KEY_FILE="$_fk"; echo "[funding] FUND_ACTION_KEY_FILE → wallet UTXO $_fk" >&2; fi
    fi
    if [ -f "$NW" ] && [ -z "${CHANGE_ADDRESS:-}" ]; then
        _fresh="$("$WPY" "$NW" next-change 2>/dev/null || true)"
        if [ -n "$_fresh" ]; then export CHANGE_ADDRESS="$_fresh"; echo "[hygiene] change → fresh $_fresh" >&2; fi
    fi
fi

cd "$ROOT"
if [ "$quiet_stderr" = "1" ]; then exec "${cmd[@]}" 2>/dev/null; else exec "${cmd[@]}"; fi
