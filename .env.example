# bonsai-notary (composed) — environment template
#
# Copy to `.env` and adjust for your machine. NEVER commit a real `.env`.
# All actual secrets live OUTSIDE the repo under $BONSAI_NOTARY_HOME — this file holds
# paths/knobs only, no secret values.

# --- the three composed pieces (symlinks today; GitHub checkouts later) ----------------------
# Inference engine checkout (trinote under <dir>/bonsai/src). Default if unset: ./engine
BONSAI_ENGINE_DIR=/home/youruser/integer_inference_engine
# On-chain software checkout (CLIs under <dir>/build). Default if unset: ./chain_c
BONSAI_CHAIN_C_DIR=/home/youruser/chain_c
# Where the model weights live (gguf + safetensors + identity). Default: ~/bonsai-notarized-bitnet
BONSAI_WEIGHTS_REPO=/home/youruser/bonsai-notarized-bitnet

# --- shared state / secrets home (engine receipts+keys AND chain_c key files) -----------------
# Both subsystems are pointed here so they agree on one home and reuse the same keys.
# Default if unset: ~/.local/trinote
BONSAI_NOTARY_HOME=/home/youruser/.local/trinote

# Committed AgentTea contract artifact chain_c reconstructs the locking script from.
# Default if unset: <chain_c>/artifacts/src/contracts-next/agentTea.json
# BONSAI_AGENT_TEA_ARTIFACT=/home/youruser/chain_c/artifacts/src/contracts-next/agentTea.json

# --- engine knobs -----------------------------------------------------------------------------
# 1 = use the GPU producer on native modes (default); 0 = force CPU.
BONSAI_GPU=1
# Native inference thread count for the int-ref engine.
OMP_NUM_THREADS=8
# PrismML llama.cpp build/bin dir (tokenizer). Default resolved under $BONSAI_NOTARY_HOME/vendor.
# BONSAI_BIN_DIR=/home/youruser/.config/bonsai/prismml_bin
